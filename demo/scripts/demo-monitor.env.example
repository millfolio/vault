# demo-monitor config — copy to ~/.config/millfolio/demo-monitor.env on the demo host
# (bgent) and fill in the webhook. monitor.py reads this every run (no restart needed).
#
# Discord webhook: Server Settings ▸ Integrations ▸ Webhooks ▸ New Webhook ▸ Copy URL.
# Leave empty to run in log-only mode (checks + heal still happen; no push).
DISCORD_WEBHOOK_URL=

# Endpoints (defaults match the bgent demo; override only if they move).
PUBLIC_URL=https://demo.millfolio.app
LOCAL_APP=http://127.0.0.1:10010
ENGINE_URL=http://127.0.0.1:8001
ENGINE_MODEL=Qwen/Qwen2.5-3B-Instruct

# Wedge floor: healthy decode is ~10 tok/s; the wedge drops to ~0.3. 2.0 separates them.
ENGINE_FLOOR_TOKS=2.0
ENGINE_PROBE_TOKENS=16
ENGINE_TIMEOUT_S=45

# Heal only after this many consecutive fails (avoids restarting on a single blip),
# and no more than once per cooldown per service. Reminder re-alerts while still down.
FAILS_BEFORE_HEAL=2
HEAL_COOLDOWN_S=900
ALERT_REMINDER_S=1800

# launchd targets for auto-heal.
DEMO_DAEMON=system/app.millfolio.demo
ENGINE_AGENT=app.millfolio.demo-engine

# Which heals THIS monitor is responsible for. The demo can run split across two users:
# the engine is a gui agent under one (needs a gui-domain kickstart), the demo daemon
# heals via a scoped sudo rule under another. Give the engine-owner's gui monitor
# HEAL_ENGINE=1 HEAL_DEMO=0 (+ the webhook), and the demo-daemon owner HEAL_ENGINE=0
# HEAL_DEMO=1 (no webhook, so alerts aren't duplicated). A single-user host leaves both 1.
# The engine is kickstarted ONCE per wedge episode; if it stays wedged the alert
# escalates to "REBOOT REQUIRED" (the decode wedge survives a process restart).
HEAL_DEMO=1
HEAL_ENGINE=1
