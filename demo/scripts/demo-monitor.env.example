# demo-monitor config — copy to ~/.config/millfolio/demo-monitor.env on the demo host
# (bgent) and fill in the webhook. monitor.py reads this every run (no restart needed).
#
# Discord webhook: Server Settings ▸ Integrations ▸ Webhooks ▸ New Webhook ▸ Copy URL.
# Leave empty to run in log-only mode (checks + heal still happen; no push).
DISCORD_WEBHOOK_URL=

# Webhook for the twice-daily ACCESS DIGEST (demo-access-report.sh, cron 08:00+14:00):
# "N real accesses today · yesterday: M". Kept SEPARATE from the alert webhook above so
# the host that owns the access log can post the digest while staying silent on alerts
# (only one monitor should hold DISCORD_WEBHOOK_URL, else alerts duplicate). Same URL
# is fine — different purpose. Empty = digest disabled.
DISCORD_REPORT_WEBHOOK_URL=

# Endpoints (defaults match the bgent demo; override only if they move).
PUBLIC_URL=https://demo.millfolio.app
LOCAL_APP=http://127.0.0.1:10010
ENGINE_URL=http://127.0.0.1:8001
ENGINE_MODEL=Qwen/Qwen2.5-3B-Instruct

# Wedge floor: healthy decode is ~10 tok/s; the wedge drops to ~0.3. 2.0 separates them.
# The engine is DETECT+ALERT only (never auto-restarted): a wedge survives a process
# restart (needs a reboot), and warmup just needs time — so /v1/models not-ready within
# ENGINE_STARTUP_GRACE_S counts as "warming" (no alert), not a wedge.
ENGINE_FLOOR_TOKS=2.0
ENGINE_PROBE_TOKENS=16
ENGINE_TIMEOUT_S=45
ENGINE_STARTUP_GRACE_S=150

# Heal only after this many consecutive fails (avoids restarting on a single blip),
# and no more than once per cooldown per service. Reminder re-alerts while still down.
FAILS_BEFORE_HEAL=2
HEAL_COOLDOWN_S=900
ALERT_REMINDER_S=1800

# launchd targets for auto-heal.
DEMO_DAEMON=system/app.millfolio.demo
ENGINE_AGENT=app.millfolio.demo-engine

# Only the DEMO DAEMON is auto-healed (a restart clears an app-server crash/hang).
# HEAL_DEMO gates it so a two-user demo can assign it to whichever user holds the
# scoped `sudo -n launchctl kickstart` rule; set HEAL_DEMO=0 on the other monitor.
# The one that holds the webhook is the alerter (keep the webhook on ONE, to avoid
# duplicate alerts). The engine is never auto-restarted (see above).
HEAL_DEMO=1
